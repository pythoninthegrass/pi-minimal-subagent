{
  "name": "pi-minimal-subagents",
  "version": "0.1.0",
  "description": "Minimal named subagent tool for Pi. Run one configured agent on one task.",
  "type": "module",
  "keywords": [
    "pi",
    "subagent",
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --test src/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typescript": "^5.9.3"
  },
  "files": [
    "README.md",
    "package.json",
    "src"
  ]
}
